{
  "name": "testrep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "msw:init": "msw init public --save",
    "verify": "npm run build && node harness/eval/runner.mjs",
    "verify:update": "npm run build && node harness/eval/runner.mjs --update-baseline",
    "guard:baseline": "node harness/eval/guard-baseline.mjs",
    "cross-review": "node harness/review/cross-review.mjs",
    "cross-review:gate": "node harness/review/cross-review.mjs --gate",
    "harness": "npm run lint && npm test && npm run build && node harness/eval/runner.mjs && node harness/eval/guard-baseline.mjs",
    "prepare": "node -e \"var c=process.env.CI;if(!(c&&c!=='false'&&c!=='0'))require('child_process').execSync('git config core.hooksPath .githooks')\" || exit 0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-table": "^8.20.5",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "dompurify": "^3.4.7",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.53.2",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.28.0",
    "react-toastify": "^10.0.6",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "msw": "^2.6.4",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
