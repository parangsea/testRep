# ── 연동 모드 (현재: 하이브리드) ─────────────────────────────────────────────
# VITE_USE_MOCK=true 이면 MSW 는 계속 동작하지만, auth(/auth/*) 와 posts(/posts, /posts/:id)
# 요청은 MSW 가 가로채지 않고(passthrough) Vite 프록시를 통해 실제 백엔드로 전달된다.
# 나머지(menus·categories·comments·users)는 아직 MSW 더미가 응답한다(백엔드 확장 대기).
#  - true  : 하이브리드 (auth+posts 실서버, 나머지 더미)
#  - false : MSW 완전 비활성 — 모든 요청을 실제 백엔드로 (백엔드가 전 기능 구현된 뒤 사용)
VITE_USE_MOCK=true

# API base URL. axios 와 MSW 공통. 프록시를 쓰므로 same-origin '/api' 를 유지한다.
VITE_API_BASE_URL=/api

# 실제 백엔드 프록시 대상 (dev 전용). passthrough 된 /api 요청이 이 주소로 전달된다.
# 브라우저 직접 호출은 CORS(preflight 403)로 막히므로 dev 프록시 경유가 필수다.
VITE_PROXY_TARGET=http://minoservers.iptime.org/testboot

# [임시·dev 전용] 백엔드가 아직 role 을 안 내려주므로, 아래 username 은 admin UI 로 취급한다.
# 서버가 role 을 응답에 포함하면 즉시 무시되며, 그때 이 줄을 지우면 된다. 비우면 모두 일반 사용자.
VITE_ADMIN_USERNAMES=admin
