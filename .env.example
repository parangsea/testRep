# 이 파일을 .env 로 복사한 뒤 값을 채우세요. (cp .env.example .env)

# 연동 모드 토글.
#  - true  : 하이브리드(auth+posts 는 실서버 passthrough, 나머지는 MSW 더미)
#  - false : MSW 완전 비활성 — 모든 요청을 실제 백엔드로
VITE_USE_MOCK=true

# API base URL (axios + MSW 공통). 프록시를 쓰므로 보통 '/api' 유지.
VITE_API_BASE_URL=/api

# 개발 프록시 대상 — '/api' 요청을 실제 백엔드로 전달(하이브리드 passthrough 포함).
# 브라우저 직접 호출은 CORS 로 막히므로 dev 에서는 프록시 경유가 필수.
VITE_PROXY_TARGET=http://minoservers.iptime.org/testboot

# [임시·dev 전용] 백엔드가 role 을 안 내려주는 동안 admin UI 로 취급할 username(쉼표 구분).
# 비우면(기본) username 만으로는 누구도 admin 이 되지 않는다. 서버가 role 을 주면 자동 무시.
# VITE_ADMIN_USERNAMES=admin
